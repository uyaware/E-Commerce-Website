{
  "name": "nodejs",
  "version": "1.0.0",
  "description": "learn nodejs",
  "homepage": "https://github.com/uyaware/nodejs_expressjs_learn#readme",
  "bugs": {
    "url": "https://github.com/uyaware/nodejs_expressjs_learn/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uyaware/nodejs_expressjs_learn.git"
  },
  "license": "ISC",
  "author": "uy",
  "type": "commonjs",
  "main": "dist/app.js",
  "scripts": {
    "dev": "nodemon",
    "start": "tsc && node dist/app.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "start:debug": "nodemon --inspect=9229 -e ts,tsx --exec node -r ts-node/register -r tsconfig-paths/register ./src/app.ts"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.12.0",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^6.19.2",
    "@quixo3/prisma-session-store": "3.1.13",
    "@types/cookie-parser": "^1.4.10",
    "bcryptjs": "3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "express-session": "1.18.1",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "9.0.2",
    "mysql2": "3.16.2",
    "passport": "0.7.0",
    "passport-local": "1.0.0",
    "pg": "^8.18.0",
    "uuid": "11.0.5",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "@types/bcrypt": "5.0.2",
    "@types/ejs": "3.1.5",
    "@types/express": "5.0.0",
    "@types/express-session": "1.18.1",
    "@types/jsonwebtoken": "9.0.9",
    "@types/node": "^22.10.7",
    "@types/passport": "1.0.17",
    "@types/passport-local": "1.0.38",
    "@types/pg": "^8.16.0",
    "nodemon": "3.1.9",
    "prisma": "^6.3.0",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.7.3"
  },
  "nodemonConfig": {
    "watch": [
      "src"
    ],
    "ext": "ts",
    "ignore": [
      "node_modules"
    ],
    "exec": "ts-node -r tsconfig-paths/register ./src/app.ts"
  }
}
